FROM golang:1.22-bookworm AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /dhcp-exerciser ./cmd/dhcp-exerciser

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    iproute2 dnsutils curl jq iputils-ping ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /dhcp-exerciser /tests/dhcp-exerciser
COPY test/integration/run_tests.sh /tests/run_tests.sh
RUN chmod +x /tests/run_tests.sh /tests/dhcp-exerciser
ENTRYPOINT ["/bin/bash"]
